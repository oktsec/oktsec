# Binary (only at root, not cmd/oktsec/)
/oktsec
/oktsec.yaml
# Local operator config backups — may contain real secrets, never commit.
# (oktsec.yaml.example is the tracked sample and is intentionally not ignored.)
/oktsec.yaml.bak
/oktsec.yaml.demo-backup
# Timestamped backups written by `oktsec policy apply` (config.bak.<ts>[.N]).
/oktsec.yaml.bak.*
*.exe
dist/

# Keys (never commit private keys)
*.key
keys/

# Database
*.db
*.db-shm
*.db-wal

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test
testdata/
coverage.out

# Demos (local only, not committed)
demo/

# Python SDK
sdk/python/.venv/
sdk/python/*.egg-info/
sdk/python/dist/
__pycache__/
*.pyc

# Documentation build output
site/

# Node
node_modules/

