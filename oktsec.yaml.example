# ==============================================================================
# oktsec configuration — v0.15 example
# ==============================================================================
# Copy this file to `oktsec.yaml`, edit placeholders, then run `oktsec run` or
# `oktsec serve`. Every section is optional; `oktsec run` will fill in sensible
# defaults on first start and write them back to the config.
#
# Docs: https://github.com/oktsec/oktsec (README) + ./documentation/
# Issues: https://github.com/oktsec/oktsec/issues
# ==============================================================================

version: "1"

# ---- HTTP server (the proxy + dashboard) -------------------------------------
server:
  port: 8080
  bind: 127.0.0.1            # Keep loopback unless you terminate TLS upstream.
  log_level: info            # debug | info | warn | error
  require_intent: false      # When true, rejects messages without a declared intent.

# ---- Agent identity + keys ---------------------------------------------------
identity:
  keys_dir: ./keys           # Directory with <agent>.pub and the private keys.
  require_signature: true    # Production: true. Set false ONLY for gradual onboarding.

# ---- Named network scopes (optional) -----------------------------------------
trust_boundaries:
  internal:                  # Agents can reference this list as `scope: internal`.
    - 10.0.0.0/8
    - 192.168.0.0/16
    - api.example.internal

# ---- Default ACL policy ------------------------------------------------------
default_policy: deny         # allow (default) | deny. Use deny in production.

# ---- Database + retention ----------------------------------------------------
db_backend: sqlite           # sqlite (default) | postgres
db_path: ~/.oktsec/oktsec.db # SQLite path. Ignored when backend=postgres.
# db_dsn: postgres://user:pass@host:5432/oktsec?sslmode=require

quarantine:
  retention_days: 90         # Auto-prune quarantined items older than this.

# ---- Rate limiting -----------------------------------------------------------
rate_limit:
  per_agent: 60              # Messages per window per agent. 0 disables.
  window: 60                 # Window size in seconds.
  per_ip: 600                # Optional cap per source IP. Defaults to 10x per_agent.
  backend: memory            # memory (default) | redis
  # redis_url: redis://user:pass@localhost:6379/0

# ---- Agents (the roster) -----------------------------------------------------
# Each agent has an Ed25519 keypair (generated by `oktsec keygen <name>`),
# an ACL of who it can message, and optional tool / egress / concurrency caps.
agents:
  research-agent:
    description: "Reads public sources, drafts briefs."
    can_message: [analysis-agent]
    blocked_content: [credentials, pii]
    scan_profile: strict             # strict | content-aware | minimal
    # key_version: 1                 # Pin to enforce post-rotation replay protection.
    # max_concurrent_calls: 5        # Gateway-wide per-agent concurrency cap.
    # max_delegation_depth: 3        # How deep this agent can delegate.

  analysis-agent:
    description: "Aggregates briefs, generates reports."
    can_message: [research-agent, reporting-agent]
    blocked_content: [system-prompts]
    allowed_tools: [read_file, list_files, fetch_url]   # Empty = all allowed
    tool_policies:
      fetch_url:
        rate_limit: 30                                  # Calls per hour.
      transfer_funds:
        max_amount: 1000.0
        daily_limit: 5000.0
        require_approval_above: 500.0
    egress:
      scope: internal                                   # internal | external | custom
      allowed_domains: [api.openai.com]

  reporting-agent:
    can_message: []
    blocked_content: []

# ---- Rule enforcement overrides (optional) -----------------------------------
# Default behaviour is set in rules/*.yaml. Override severity or action here.
rules:
  - id: block-relay-injection
    severity: critical
    action: block
    notify: [slack]
  - id: quarantine-pii-leak
    severity: high
    action: quarantine
  - id: flag-broad-permissions
    severity: medium
    action: allow-and-flag

# ---- Webhooks (event delivery) -----------------------------------------------
webhooks:
  - name: slack
    url: https://hooks.slack.com/services/PLACEHOLDER
    events: [blocked, quarantined]
  # - name: pagerduty
  #   url: https://events.pagerduty.com/v2/enqueue
  #   events: [blocked]

# ---- MCP Gateway (optional) --------------------------------------------------
gateway:
  enabled: true
  port: 9090
  bind: 127.0.0.1
  endpoint_path: /mcp
  scan_responses: true         # Scan backend responses (recommended).
  dep_check: true              # Hash dependency manifests on startup (rug-pull detection).
  disable_auto_register: false # Set true in prod to reject unknown agent names.

# ---- MCP backends fronted by the gateway ------------------------------------
mcp_servers:
  fetch:
    transport: stdio
    command: uvx
    args: [mcp-server-fetch]
  filesystem:
    transport: stdio
    command: npx
    args: ["-y", "@modelcontextprotocol/server-filesystem", "/tmp/oktsec-sandbox"]
    egress_sandbox: false       # true = force backend HTTP through oktsec's forward proxy.

# ---- Forward proxy (optional, for Docker Sandbox etc.) -----------------------
forward_proxy:
  enabled: false
  bind: 127.0.0.1:8083
  scan_requests: true
  scan_responses: true

# ---- LLM threat intel (optional) ---------------------------------------------
# Oktsec never calls an LLM on the security hot path. Enable this for async
# triage / deep analysis of flagged events only.
llm:
  enabled: false
  provider: openai               # openai | claude | webhook
  model: gpt-4o-mini
  base_url: https://api.openai.com/v1
  api_key_env: OPENAI_API_KEY    # Preferred over `api_key:`.
  # api_key: sk-...              # Inline key (use only if env var is impractical).
  max_tokens: 2048
  temperature: 0.1
  max_concurrent: 3
  queue_size: 100
  timeout: 30s
  max_daily_requests: 500
  two_stage: true                # Fast classifier → full analysis.
  min_content_length: 32
  budget:
    daily_limit: 20              # USD
    monthly_limit: 1200
  fallback:
    provider: none               # none | openai | claude
  escalation:
    enabled: true
    risk_threshold: 80
    ttl_minutes: 30

# ---- Anomaly detection -------------------------------------------------------
anomaly:
  check_interval: 60             # Seconds between risk recomputes.
  risk_threshold: 80             # Score that triggers an alert.
  min_messages: 10
  auto_suspend: false            # true = suspend agents above threshold automatically.

# ---- Alerts (webhook fan-out) ------------------------------------------------
alerting:
  cooldown: 300                  # Min seconds between duplicate alerts per (event, agent).

# ---- Telemetry (anonymous install ping) --------------------------------------
telemetry:
  disabled: false                # Set true, or export OKTSEC_NO_TELEMETRY=1, to opt out.
  tracing:
    enabled: false               # OpenTelemetry trace recording. Propagation works either way.
    exporter: stdout             # stdout | none
    sampling_ratio: 1.0
    service_name: oktsec

# ---- Filesystem integrity guard (optional) -----------------------------------
guard:
  enabled: false
  # watch_paths:
  #   - ~/.cursor/mcp.json
  #   - ~/Library/Application Support/Claude/claude_desktop_config.json

# ---- Audit export for testcases (optional) -----------------------------------
audit:
  export_blocked: false          # true = dump blocked/quarantined events to ~/.oktsec/testcases.
